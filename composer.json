{
    "name": "stasis/ext-vite",
    "description": "Vite extension for Stasis",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/stasis-php/ext-vite",
    "authors": [
        {
            "name": "Volodymyr Stelmakh",
            "homepage": "https://github.com/vstelmakh"
        }
    ],
    "require": {
        "php": "^8.4",
        "stasis/stasis": "^0.2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^v3.93",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^13",
        "twig/twig": "^3"
    },
    "autoload": {
        "psr-4": {
            "Stasis\\Extension\\Vite\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Stasis\\Extension\\Vite\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
